{
  "name": "clubsoft-website",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "node --env-file=.runtime.env server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:admin": "bash -c 'set -a; . ~/.credentials; set +a; CYPRESS_ADMIN_EMAIL=\"$CLUBSOFT_ADMIN_EMAIL\" CYPRESS_ADMIN_PASSWORD=\"$CLUBSOFT_ADMIN_PASSWORD\" cypress run --spec cypress/e2e/admin-login.cy.ts'",
    "test:admin:prod": "bash -c 'set -a; . ~/.credentials; set +a; CYPRESS_ADMIN_EMAIL=\"$CLUBSOFT_ADMIN_EMAIL\" CYPRESS_ADMIN_PASSWORD=\"$CLUBSOFT_ADMIN_PASSWORD\" CYPRESS_BASE_URL=https://svthalexweiler.de cypress run --spec cypress/e2e/admin-login.cy.ts'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.9",
    "@tailwindcss/vite": "^4.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.9.0",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-image-crop": "^11.0.10",
    "react-router-dom": "^7.13.1",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "slug": "^11.0.1",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.5",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^4.7.0",
    "cypress": "^15.12.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
